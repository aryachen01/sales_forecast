# ── Python 编译缓存 ──────────────────────────────────
__pycache__/
*.py[cod]

# ── 模型二进制文件（体积大，由运行产生） ───────────────
*.pkl
*.pickle

# ── 防止运行产物意外落入仓库 ──────────────────────────
outputs/
runs/
*.log

# ── 本机运行/分析记录（仅本地保留，不进仓库） ────────
report_generator_model_compare/

# ── 凭证与敏感配置（绝不上传 GitHub）────────────────
.env
*-key.json
*_key.json
service_account*.json

# ── Python 虚拟环境 ──────────────────────────────────
.venv/
venv/
env/

# ── IDE / 系统文件 ───────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
